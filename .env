OPENAI_API_KEY=

# Optional — only if you want server-side AI instead of Puter (client-side, zero-config).
# Groq free tier example:
# OPENAI_API_KEY=gsk_...
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile

# Default OpenAI:
# OPENAI_MODEL=gpt-4o-mini

# Optional local Ollama (auto-detected when running npm run dev):
# OLLAMA_MODEL=llama3.2
